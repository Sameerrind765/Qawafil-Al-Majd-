rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Leads / Pilgrim inquiries: Public can submit them, but only authenticated operators can read, edit or delete them.
    match /leads/{leadId} {
      allow read, update, delete: if isSignedIn();
      allow create: if true;
    }

    // Vehicles: Only authenticated operators can view or manage them on the dashboard.
    match /vehicles/{vehicleId} {
      allow read, write: if isSignedIn();
    }

    // Cargo Orders: Only authenticated operators can view or manage them on the dashboard.
    match /cargoOrders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Transactions / Account Ledger records: Only authenticated operators can manage them on the dashboard.
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Receipts: Only authenticated operators or owners can view or manage scanned receipts.
    match /receipts/{receiptId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.driver_uid == request.auth.uid ||
        resource.data.driver_id == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['superadmin', 'admin', 'viewer'])
      );
      allow create: if isSignedIn() && (
        request.resource.data.driver_uid == request.auth.uid ||
        request.resource.data.driver_id == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['superadmin', 'admin'])
      );
      allow update: if isSignedIn() && (
        (resource.data.driver_uid == request.auth.uid && request.resource.data.driver_uid == request.auth.uid) ||
        (resource.data.driver_id == request.auth.uid && request.resource.data.driver_id == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['superadmin', 'admin'])
      );
      allow delete: if isSignedIn() && (
        resource.data.driver_uid == request.auth.uid ||
        resource.data.driver_id == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')
      );
    }

    // Settings (e.g. google_sheets config): Only authenticated operators can read/write.
    match /settings/{docId} {
      allow read, write: if isSignedIn();
    }

    // User Profile matching: Allow full collection queries for authenticated admins, lock modifications to the profile owner or superadmins.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == uid || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'));

      match /folders/{folderId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /files/{fileId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /notes/{noteId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /teamMembers/{memberId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }
  }
}
